# Local eval-runner outputs — created by scripts/run-content-evals.sh
skills-workspace/

# Real-world probe run outputs — created by evals/real-world/run-real-world.sh
evals/real-world/runs/

# Python bytecode (grade-iteration.py + future helpers)
__pycache__/
*.pyc

# Stray logs (also covered by skills-workspace/ but be explicit)
*.log

# OS / editor noise
.DS_Store
*.swp

# Playwright MCP runtime artifacts (logs + page snapshots)
.playwright-mcp/

# Claude Code local-only config — personal paths + runtime lock.
# settings.json, skills/, agents/, hooks/ under .claude/ ARE tracked (shared dev tooling).
.claude/settings.local.json
.claude/scheduled_tasks.lock

